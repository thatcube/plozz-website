---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import SavedSections from '../components/SavedSections.astro';
import { faqs, stripHtml } from '../data/faqs';

const GITHUB_URL = 'https://github.com/thatcube/Plozz';
const DONATE_URL = 'https://github.com/sponsors/thatcube';
const TESTFLIGHT_URL = 'https://testflight.apple.com/join/EKfReNMu';
const SITE = 'https://plozz.app';

const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Plozz',
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'tvOS 17+',
  description:
    'Plozz is a free, open-source native Apple TV (tvOS) client for Jellyfin and Plex. Watch your own movies, shows, and music with Quick Connect sign-in, resume support, and native tvOS playback.',
  url: SITE,
  image: `${SITE}/og-image.png`,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  license: 'https://www.gnu.org/licenses/gpl-3.0.html',
  isAccessibleForFree: true,
  author: { '@type': 'Organization', name: 'thatcube', url: 'https://github.com/thatcube' },
  sameAs: [GITHUB_URL],
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.a) },
  })),
};
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-logo-wrap">
          <img class="hero-logo" src="/logo.svg" alt="" aria-hidden="true" width="96" height="96" />
        </div>
        <h1 class="hero-title">
          <img class="hero-wordmark" src="/plozz-wordmark.svg" alt="" aria-hidden="true" width="56" height="28" />
          <span class="sr-only">Plozz — native Jellyfin &amp; Plex client for Apple TV</span>
        </h1>
        <p class="lead">Native tvOS app for Jellyfin &amp; Plex. Free and open source.</p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg btn-cta" href={TESTFLIGHT_URL} target="_blank" rel="noopener">
            <Icon name="simple-icons:apple" />
            Join the TestFlight beta
          </a>
          <a class="btn btn-light btn-lg" href={GITHUB_URL} target="_blank" rel="noopener">
            <Icon name="simple-icons:github" />
            GitHub
          </a>
        </div>
      </div>
    </section>

    <SavedSections />

  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-brand">
        <img src="/logo.svg" alt="" width="22" height="22" />
        <span>Plozz</span>
      </div>
      <div class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
        <a href={`${GITHUB_URL}/issues`} target="_blank" rel="noopener">Send feedback</a>
        <a class="btn btn-ghost btn-sm" href={DONATE_URL} target="_blank" rel="noopener">
          <Icon name="ph:heart" />
          Donate
        </a>
      </div>
      <div>© {new Date().getFullYear()} Plozz · GPL-3.0</div>
    </div>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(softwareLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
</Layout>
