---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const GITHUB_URL = 'https://github.com/thatcube/Plozz';
const DONATE_URL = 'https://github.com/sponsors/thatcube';
const TESTFLIGHT_URL = 'https://testflight.apple.com/join/EKfReNMu';
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-logo-wrap">
          <img class="hero-logo" src="/logo.svg" alt="" aria-hidden="true" width="96" height="96" />
        </div>
        <h1 class="hero-title">
          <img class="hero-wordmark" src="/plozz-wordmark.svg" alt="Plozz" width="56" height="28" />
        </h1>
        <p class="lead">Native tvOS app for Jellyfin &amp; Plex. Free and open source.</p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg btn-cta" href={TESTFLIGHT_URL} target="_blank" rel="noopener">
            <Icon name="simple-icons:apple" />
            Join the TestFlight beta
          </a>
          <a class="btn btn-light btn-lg" href={GITHUB_URL} target="_blank" rel="noopener">
            <Icon name="simple-icons:github" />
            GitHub
          </a>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-brand">
        <img src="/logo.svg" alt="" width="22" height="22" />
        <span>Plozz</span>
      </div>
      <div class="footer-links">
        <a href="/privacy">Privacy</a>
        <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
        <a href={`${GITHUB_URL}/issues`} target="_blank" rel="noopener">Send feedback</a>
        <a class="btn btn-ghost btn-sm" href={DONATE_URL} target="_blank" rel="noopener">
          <Icon name="ph:heart" />
          Donate
        </a>
      </div>
      <div>© {new Date().getFullYear()} Plozz · GPL-3.0</div>
    </div>
  </footer>
</Layout>
