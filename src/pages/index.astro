---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const GITHUB_URL = 'https://github.com/thatcube/Plozz';
const SPONSOR_URL = 'https://github.com/sponsors/thatcube';
// TODO: replace with your public TestFlight invite link once the beta opens.
const TESTFLIGHT_URL = 'https://testflight.apple.com/';

const features = [
  {
    title: 'Jellyfin & Plex',
    body: 'Connect a Jellyfin or Plex server. Everything above the provider layer is identical, so Home, detail, and playback feel exactly the same either way.',
    icon: 'ph:hard-drives',
  },
  {
    title: 'Couch-friendly sign-in',
    body: 'Jellyfin Quick Connect and Plex Link show a code and sign you in — no typing passwords with the remote. Your session is restored on relaunch.',
    icon: 'ph:key',
  },
  {
    title: 'Cinematic detail pages',
    body: 'Full-bleed backdrops that fade into the background, with logos, overviews, ratings, and focus-driven season tabs for series done right.',
    icon: 'ph:film-slate',
  },
  {
    title: 'Plays anything',
    body: 'Direct play whenever possible, with automatic on-device engine routing for tricky formats like AV1, 10-bit HEVC, and image-based subtitles.',
    icon: 'ph:play-circle',
  },
  {
    title: 'Resume & watched state',
    body: 'Pick up right where you left off. Per-episode watched badges, "mark watched up to here," and progress reported back to your server.',
    icon: 'ph:bookmark-simple',
  },
  {
    title: 'Made yours',
    body: 'System, Dark, OLED, and Light themes. Multiple local profiles. Full caption customization — font, size, color, opacity, background, and edges.',
    icon: 'ph:sliders-horizontal',
  },
];

const JELLYFIN_PATH =
  'M12 .002C8.826.002-1.398 18.537.16 21.666c1.56 3.129 22.14 3.094 23.682 0C25.384 18.573 15.177 0 12 0zm7.76 18.949c-1.008 2.028-14.493 2.05-15.514 0C3.224 16.9 9.92 4.755 12.003 4.755c2.081 0 8.77 12.166 7.759 14.196zM12 9.198c-1.054 0-4.446 6.15-3.93 7.189.518 1.04 7.348 1.027 7.86 0 .511-1.027-2.874-7.19-3.93-7.19z';
// Official Plex chevron geometry (normalized to a 0 0 610 1001 viewBox).
const PLEX_PATH = 'M0 0h290l320 500.25-320 500.25h-290l319.999-500.25z';

const steps = [
  {
    n: 1,
    title: 'Run a server',
    body: 'Point Plozz at a Jellyfin or Plex server you run — on your home network or anywhere online.',
  },
  {
    n: 2,
    title: 'Install on Apple TV',
    body: 'Grab the app from the TestFlight beta today. A public App Store release is planned.',
  },
  {
    n: 3,
    title: 'Sign in with a code',
    body: 'Approve a short code with Quick Connect or Plex Link. No typing passwords with the remote.',
  },
];

const faqs = [
  {
    q: 'Is Plozz really free?',
    a: 'Yes. Plozz is MIT-licensed and open source — no subscriptions, no ads, no upsells. If it\u2019s useful to you, sponsorship is welcome but never required.',
  },
  {
    q: 'Do I need my own server?',
    a: 'Yes. Plozz is a player for a Jellyfin or Plex server that you run. It doesn\u2019t host, provide, or stream any media itself.',
  },
  {
    q: 'Does Plozz collect my data or track me?',
    a: 'No accounts and no analytics. Your credentials live in the Apple TV Keychain and are only ever sent to your own server.',
  },
  {
    q: 'How do I install it?',
    a: 'An Apple TV TestFlight beta is on the way \u2014 it opens once Apple approves the build for external testing. A public App Store release is planned after that.',
  },
  {
    q: 'Will there be an iPhone or iPad app?',
    a: 'Maybe. tvOS is the focus today, but the codebase is structured so iOS and iPadOS are possible later. No promises yet.',
  },
  {
    q: 'Jellyfin or Plex \u2014 which should I use?',
    a: 'Either. Plozz treats both the same, so just use whichever server you already run.',
  },
  {
    q: 'I found a bug or want a feature.',
    a: `Open an issue on <a href="${GITHUB_URL}/issues" target="_blank" rel="noopener">GitHub</a> \u2014 that\u2019s the best place to report bugs and request features.`,
  },
];
---

<Layout>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">
        <img src="/logo.svg" alt="" width="28" height="28" />
        <span>Plozz</span>
      </a>
      <nav class="nav">
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href="#how">How it works</a>
          <a href="#platforms">Platforms</a>
          <a href="#faq">FAQ</a>
        </div>
        <a class="btn btn-ghost" href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <img class="hero-logo" src="/logo.svg" alt="Plozz" width="96" height="96" />
        <h1>Your media library,<br /><span class="accent">native on Apple TV.</span></h1>
        <p class="lead">
          Plozz is a free, open-source Apple TV app for your own server. Point it at
          Jellyfin or Plex and watch your library with a fast, cinematic, made-for-tvOS
          interface.
        </p>
        <div class="hero-cta">
          <button class="btn btn-disabled" type="button" disabled aria-disabled="true" title="The TestFlight beta opens once Apple approves the build for external testing.">
            <Icon name="ph:clock" />
            TestFlight beta — pending Apple approval
          </button>
          <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener">
            <Icon name="simple-icons:github" />
            View on GitHub
          </a>
        </div>
        <p class="hero-note">Free &amp; open source · No account, no tracking · MIT licensed</p>

        <div class="badges">
          <span class="badge">
            <svg class="blogo" viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="jf-badge" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#AA5CC3"/><stop offset="100%" stop-color="#00A4DC"/></linearGradient></defs><path fill="url(#jf-badge)" d={JELLYFIN_PATH} /></svg>
            Jellyfin
          </span>
          <span class="badge">
            <svg class="blogo blogo-plex" viewBox="0 0 610 1001" aria-hidden="true"><defs><linearGradient id="plex-badge" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#F9BE03"/><stop offset="100%" stop-color="#CC7C19"/></linearGradient></defs><path fill="url(#plex-badge)" d={PLEX_PATH} /></svg>
            Plex
          </span>
          <span class="badge"><span class="dot"></span> tvOS 17+</span>
          <span class="badge"><span class="dot"></span> Open source</span>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">What you get</span>
          <h2>Built for the living room</h2>
          <p>Everything you'd expect from a great tvOS app — and nothing you don't.</p>
        </div>
        <div class="grid">
          {
            features.map((f) => (
              <div class="card">
                <div class="icon">
                  <Icon name={f.icon} />
                </div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Providers -->
    <section id="providers" style="padding-top:0;">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">One app, your server</span>
          <h2>Bring your own backend</h2>
          <p>Plozz never hosts your media. It connects to a server you already run.</p>
        </div>
        <div class="provider-grid">
          <div class="provider-card">
            <svg class="plogo" viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="jf-card" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#AA5CC3"/><stop offset="100%" stop-color="#00A4DC"/></linearGradient></defs><path fill="url(#jf-card)" d={JELLYFIN_PATH} /></svg>
            <div>
              <h3>Jellyfin</h3>
              <p>The free, open-source media server. Zero-config LAN discovery and Quick Connect.</p>
            </div>
          </div>
          <div class="provider-card">
            <svg class="plogo plogo-plex" viewBox="0 0 610 1001" aria-hidden="true"><defs><linearGradient id="plex-card" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#F9BE03"/><stop offset="100%" stop-color="#CC7C19"/></linearGradient></defs><path fill="url(#plex-card)" d={PLEX_PATH} /></svg>
            <div>
              <h3>Plex</h3>
              <p>The popular media server platform. Sign in with the Plex Link code flow.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how" style="background:var(--bg-elev);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Get started</span>
          <h2>Up and running in minutes</h2>
          <p>Three steps from your server to your couch.</p>
        </div>
        <div class="steps">
          {
            steps.map((s) => (
              <div class="step">
                <div class="num">{s.n}</div>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Platforms -->
    <section id="platforms">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Where it runs</span>
          <h2>Apple TV today</h2>
          <p>Plozz is built for tvOS first. iPhone and iPad may follow.</p>
        </div>
        <div class="platforms">
          <div class="platform">
            <Icon name="ph:television-simple" class="picon" />
            <h3>Apple TV</h3>
            <span class="status live">Available now</span>
            <p>Native tvOS 17+ app, tuned for the remote and the big screen.</p>
          </div>
          <div class="platform future">
            <Icon name="ph:device-mobile" class="picon" />
            <h3>iPhone &amp; iPad</h3>
            <span class="status soon">Maybe later</span>
            <p>On the radar — no promises, but the architecture is ready for it.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" style="background:var(--bg-elev);border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">Questions</span>
          <h2>Frequently asked</h2>
          <p>The quick answers. Anything else? Ask on GitHub.</p>
        </div>
        <div class="faq">
          {
            faqs.map((item) => (
              <details>
                <summary>
                  {item.q}
                  <Icon name="ph:caret-down" class="chev" />
                </summary>
                <p set:html={item.a} />
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Open source -->
    <section id="open-source" class="oss">
      <div class="container">
        <div class="oss-card">
          <h2>Free and open source</h2>
          <p>
            Plozz is MIT-licensed and built in the open. Read the code, file an issue,
            or contribute a feature. If it's useful to you, sponsorship keeps it going.
          </p>
          <div class="oss-cta">
            <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener">
              <Icon name="ph:star-fill" />
              Star on GitHub
            </a>
            <a class="btn btn-sponsor" href={SPONSOR_URL} target="_blank" rel="noopener">
              <Icon name="ph:heart-fill" />
              Sponsor
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-brand">
        <img src="/logo.svg" alt="" width="22" height="22" />
        <span>Plozz</span>
      </div>
      <div class="footer-links">
        <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
        <a href={SPONSOR_URL} target="_blank" rel="noopener">Sponsor</a>
        <a href={`${GITHUB_URL}/issues`} target="_blank" rel="noopener">Support</a>
      </div>
      <div>© {new Date().getFullYear()} Plozz · MIT</div>
    </div>
  </footer>
</Layout>
